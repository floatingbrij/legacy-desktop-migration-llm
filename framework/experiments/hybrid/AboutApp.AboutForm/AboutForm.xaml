<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AboutApp.AboutForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AboutApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:Name="RootGrid">
        <TextBlock x:Name="lblAppName" Text="My Application" Width="200" Height="30" Margin="50,20,0,0"/>
        <TextBlock x:Name="lblVersion" Text="Version 1.0.0" Width="200" Height="20" Margin="50,60,0,0"/>
        <TextBlock x:Name="lblCopyright" Text="(c) 2024 Company" Width="200" Height="20" Margin="50,90,0,0"/>
        <Button x:Name="btnOK" Content="OK" Width="90" Height="30" Margin="100,130,0,0" Click="btnOK_Click"/>
        <HyperlinkButton x:Name="lnkWebsite" Content="www.example.com" Width="200" Height="20" Margin="50,120,0,0"/>
    </Grid>
</Window>