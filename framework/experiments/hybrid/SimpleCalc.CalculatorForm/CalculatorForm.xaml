<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleCalc.CalculatorForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SimpleCalc"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:Name="RootGrid">
        <TextBox x:Name="txtDisplay" Text="0" PlaceholderText="" Width="260" Height="39" Margin="12,12,0,0"/>
        <Button x:Name="btn1" Content="1" Width="60" Height="50" Margin="12,70,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn2" Content="2" Width="60" Height="50" Margin="78,70,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn3" Content="3" Width="60" Height="50" Margin="144,70,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn4" Content="4" Width="60" Height="50" Margin="12,126,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn5" Content="5" Width="60" Height="50" Margin="78,126,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn6" Content="6" Width="60" Height="50" Margin="144,126,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn7" Content="7" Width="60" Height="50" Margin="12,182,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn8" Content="8" Width="60" Height="50" Margin="78,182,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn9" Content="9" Width="60" Height="50" Margin="144,182,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btn0" Content="0" Width="126" Height="50" Margin="12,238,0,0" Click="btnNumber_Click"/>
        <Button x:Name="btnAdd" Content="+" Width="60" Height="50" Margin="210,70,0,0" Click="btnOperator_Click"/>
        <Button x:Name="btnSubtract" Content="-" Width="60" Height="50" Margin="210,126,0,0" Click="btnOperator_Click"/>
        <Button x:Name="btnMultiply" Content="*" Width="60" Height="50" Margin="210,182,0,0" Click="btnOperator_Click"/>
        <Button x:Name="btnDivide" Content="/" Width="60" Height="50" Margin="210,238,0,0" Click="btnOperator_Click"/>
        <Button x:Name="btnEquals" Content="=" Width="60" Height="50" Margin="144,238,0,0" Click="btnEquals_Click"/>
        <Button x:Name="btnClear" Content="Clear" Width="260" Height="40" Margin="12,294,0,0" Click="btnClear_Click"/>
        <TextBlock x:Name="lblResult" Text="" Width="260" Height="20" Margin="12,340,0,0"/>
    </Grid>
</Window>