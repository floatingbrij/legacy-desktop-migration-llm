<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ContactsManager.ContactsForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ContactsManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:Name="RootGrid">
        <TextBlock x:Name="lblName" Text="Name:" Width="60" Height="20" Margin="20,20,0,0"/>
        <TextBox x:Name="txtName" Text="" PlaceholderText="" Width="200" Height="23" Margin="90,17,0,0" TextChanged="txtName_TextChanged"/>
        <TextBlock x:Name="lblEmail" Text="Email:" Width="60" Height="20" Margin="20,50,0,0"/>
        <TextBox x:Name="txtEmail" Text="" PlaceholderText="" Width="200" Height="23" Margin="90,47,0,0"/>
        <TextBlock x:Name="lblPhone" Text="Phone:" Width="60" Height="20" Margin="20,80,0,0"/>
        <TextBox x:Name="txtPhone" Text="" PlaceholderText="" Width="200" Height="23" Margin="90,77,0,0"/>
        <Button x:Name="btnAdd" Content="Add" Width="75" Height="28" Margin="310,17,0,0" Click="btnAdd_Click"/>
        <Button x:Name="btnDelete" Content="Delete" Width="75" Height="28" Margin="310,50,0,0" Click="btnDelete_Click"/>
        <Button x:Name="btnEdit" Content="Edit" Width="75" Height="28" Margin="310,83,0,0" Click="btnEdit_Click"/>
        <ListView x:Name="lvContacts" Width="660" Height="300" Margin="20,120,0,0" SelectionChanged="lvContacts_SelectedIndexChanged"/>
        <TextBox x:Name="txtSearch" Text="" PlaceholderText="" Width="200" Height="23" Margin="20,430,0,0" TextChanged="txtSearch_TextChanged"/>
        <TextBlock x:Name="lblSearch" Text="Search:" Width="60" Height="20" Margin="20,410,0,0"/>
        <TextBlock x:Name="lblCount" Text="0 contacts" Width="100" Height="20" Margin="580,430,0,0"/>
    </Grid>
</Window>