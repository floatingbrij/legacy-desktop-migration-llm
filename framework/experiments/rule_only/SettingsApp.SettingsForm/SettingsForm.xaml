<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SettingsApp.SettingsForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SettingsApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:Name="RootGrid">
        <TextBlock x:Name="lblTheme" Text="Theme:" Width="80" Height="20" Margin="20,20,0,0"/>
        <ComboBox x:Name="cmbTheme" Width="200" Height="23" Margin="110,17,0,0" SelectionChanged="cmbTheme_SelectedIndexChanged"> </ComboBox>
        <CheckBox x:Name="chkAutoSave" Content="Auto-save" IsChecked="False" Width="150" Height="20" Margin="20,60,0,0" Checked="chkAutoSave_CheckedChanged"/>
        <CheckBox x:Name="chkNotify" Content="Notifications" IsChecked="False" Width="150" Height="20" Margin="20,90,0,0"/>
        <Button x:Name="btnSave" Content="Save" Width="90" Height="30" Margin="120,180,0,0" Click="btnSave_Click"/>
        <Button x:Name="btnCancel" Content="Cancel" Width="90" Height="30" Margin="220,180,0,0" Click="btnCancel_Click"/>
    </Grid>
</Window>